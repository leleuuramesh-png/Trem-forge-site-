# Copie para variáveis de ambiente no Netlify (Site settings > Environment variables).
# Nunca commite sua chave real neste arquivo nem em nenhum outro.

ANTHROPIC_API_KEY=sk-ant-sua-chave-aqui

# Opcional — modelo a usar (padrão: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Obrigatória para o painel de autorizações de portfólio (admin-portfolio.html)
ADMIN_PASSWORD=escolha-uma-senha-forte-aqui

# Mercado Pago — assinaturas recorrentes (mp-subscribe.js / mp-webhook.js)
# Access Token: painel do Mercado Pago > Suas integrações > Credenciais
MP_ACCESS_TOKEN=APP_USR-sua-chave-aqui
# Webhook secret: painel do Mercado Pago > Suas integrações > Webhooks
MP_WEBHOOK_SECRET=sua-assinatura-secreta-aqui

# URL pública do site (sem barra no final). Usada nos back_url de checkout.
# Se não definida, o código tenta inferir pelo header Host da requisição.
SITE_URL=https://tremforge.com
